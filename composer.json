{
  "name": "orph/stack",
  "description": "stack for wordpress",
  "type": "wp-stack",
  "autoload": {
    "psr-4": {
      "Orph\\Stack\\": "src/"
    }
  },
  "authors": [
    {
      "name": "alexandre",
      "email": "alexandre.mr.billereau@gmail.com"
    }
  ],
  "config": {
    "allow-plugins": {}
  },
  "extra": {
    "strauss": {
      "target_directory": "composer-build",
      "namespace_prefix": "Test_Vendor\\Vendor\\",
      "classmap_prefix": "Test_Vendor_Vendor_",
      "optimize_autoloader": true
    }
  },
  "scripts": {
    "prefix-namespaces": [
      "sh -c 'test -f ./bin/strauss.phar || curl -fsSL -o bin/strauss.phar -L https://github.com/BrianHenryIE/strauss/releases/latest/download/strauss.phar'",
      "@php bin/strauss.phar",
      "@composer dump-autoload"
    ],
    "post-install-cmd": [
      "@prefix-namespaces"
    ],
    "post-update-cmd": [
      "@prefix-namespaces"
    ]
  },
  "require": {}
}
